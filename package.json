{
  "name": "nodejs-template",
  "version": "1.0.0",
  "description": "This is my nodejs template.",
  "keywords": [],
  "author": "y.idakko@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanoshi-1009/nodejs-template"
  },
  "type": "module",
  "main": "index.js",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.0.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "build": "node ./scripts/esbuild/build.ts && zip -rj dist/build.zip dist/index.mjs"
  },
  "devDependencies": {
    "@cybozu/eslint-config": "25.0.1",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "prettier": "3.8.3"
  },
  "dependencies": {}
}
